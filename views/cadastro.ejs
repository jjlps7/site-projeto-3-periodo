<!DOCTYPE html>
<html lang="pt-br">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>Cadastro</title>
        <link rel="stylesheet" href="/css/style.css" />
    </head>

    <body class="cadastro-body">
        <div class="cadastro-container">
            <img
                src="/imgs/Logo_circular.png"
                alt="Imagem com fundo branco com os dizeres B5 de forma estilizada e Base 5 em azul e automações em preto"
                class="logo-login-cadastro"
            />
            <div class="cadastro-card">
                <% if (aviso === 'duplicado') { %>
                <div
                    style="
                        width: 100%;
                        box-sizing: border-box;
                        background-color: #f8d7da;
                        color: #721c24;
                        padding: 12px;
                        border-radius: 8px;
                        border: 1px solid #f5c6cb;
                        margin-bottom: 20px;
                        text-align: center;
                        font-size: 0.9rem;
                    "
                >
                    <strong>Erro de Cadastro:</strong>
                    Este e-mail já está registado no sistema.
                </div>
                <% } %>
                <form id="form-cadastro" action="/cadastro" method="post">
                    <h1>Crie sua conta</h1>

                    <div class="campo-nome">
                        <label for="nome">Nome</label>
                        <input
                            type="text"
                            name="nome"
                            id="nome"
                            placeholder="Digite seu nome"
                            tabindex="1"
                            required
                        />
                    </div>

                    <div class="campo-cpf">
                        <label for="cpf">CPF</label>
                        <input
                            type="text"
                            name="cpf"
                            id="cpf"
                            placeholder="Informe seu CPF"
                            tabindex="2"
                            maxlength="14"
                            required
                        />
                    </div>

                    <div class="campo-email">
                        <label for="email">E-Mail</label>
                        <input
                            type="email"
                            name="email"
                            id="email"
                            placeholder="Digite seu e-mail"
                            tabindex="3"
                            required
                        />
                        <p class="aviso-senhas" id="aviso-email" aria-live="polite"></p>
                        <!-- O JS escreve conforme a pessoa digita-->
                    </div>

                    <div class="campo-confirmar-email">
                        <label for="confirmar_email">Confirme seu E-Mail</label>
                        <input
                            type="email"
                            name="confirmar_email"
                            id="confirmar_email"
                            placeholder="Confirme seu e-mail"
                            tabindex="4"
                            required
                        />
                        <p class="aviso-senhas" id="aviso-confirmar-email" aria-live="polite"></p>
                    </div>

                    <div class="campo-senha">
                        <label for="senha">Senha</label>
                        <input
                            type="password"
                            name="senha"
                            id="senha"
                            placeholder="Digite sua senha"
                            tabindex="5"
                            required
                        />
                        <ul class="requisitos-senha" id="requisitos-senha">
                            <li id="req-tamanho" class="requisito">
                                <span class="icone">✗</span>
                                8 caracteres
                            </li>
                            <li id="req-maiuscula" class="requisito">
                                <span class="icone">✗</span>
                                1 letra maiúscula
                            </li>
                            <li id="req-numero" class="requisito">
                                <span class="icone">✗</span>
                                1 número
                            </li>
                        </ul>
                    </div>

                    <div class="campo-confirmar-senha">
                        <label for="confirmar_senha">Confirme sua senha</label>
                        <input
                            type="password"
                            name="confirmar_senha"
                            id="confirmar_senha"
                            placeholder="Confirme sua senha"
                            tabindex="6"
                            required
                        />
                        <p class="aviso-senhas" id="aviso-senhas" aria-live="polite"></p>
                        <!-- O JS escreve conforme a pessoa digita-->
                    </div>

                    <div class="cadastro-botao">
                        <button type="reset" tabindex="7">Apagar</button>
                        <button type="submit" tabindex="8">Criar</button>
                    </div>
                </form>
                <p>
                    Já tem conta?
                    <a href="/login" tabindex="9">Login</a>
                </p>
            </div>
        </div>

        <script>
            // máscara CPF
            const inputCpf = document.getElementById('cpf');
            // pega o input através do ID
            inputCpf.addEventListener('input', function(e){ //detecta mudanças no campo conforme é feito
                let valor = e.target.value; //pega o texto digitado 

                valor = valor.replace(/\D/g, ""); //qualquer caractere que não seja número é ignorado
                valor = valor.replace(/(\d{3})(\d)/, "$1.$2"); //pega os 3 primeiros números e o próximo e add um ponto entre eles
                valor = valor.replace(/(\d{3})(\d)/, "$1.$2");
                valor = valor.replace(/(\d{3})(\d{1,2})$/, "$1-$2"); //pega o bloco dos últimos 3 e os últimos 2 e adiciona um - entre

                e.target.value = valor; //devolve o valor formatado
            });


            // pega os inputs do formulário
            const campos = document.querySelectorAll('input');
            // percorre cada um
            campos.forEach(function (campo, index) {
                campo.addEventListener('keydown', function (e) {
                    // verifica se uma tecla é pressionada no campo
                    if (e.key === 'Enter') {
                        e.preventDefault(); // se for enter, cancela o comportamento padrão (enviar formulário)
                        const proximo = campos[index + 1]; // pega próximo input
                        if (proximo) {
                            proximo.focus(); //move foco pra ele
                        } else {
                            const form = document.getElementById('form-cadastro');
                            const todosCampos = Array.from(campos); // transforma a lista de campos em array para usar o .every()
                            const tudoPreenchido = todosCampos.every(function (c) {
                                // verifica se TODOS os campos passam na condição
                                return c.value.trim() !== ''; // retorna true se o campo não estiver vazio
                            });

                            if (tudoPreenchido) {
                                form.submit(); // todos preenchidos, envia
                            } else {
                                form.reportValidity(); // mostra o aviso nativo do navegador nos campos vazios
                            }
                        }
                    }
                });
            });

            // Confirmação de senha
            /* guarda os IDs do HTML */
            const inputSenha = document.getElementById('senha');
            const inputConfirmar = document.getElementById('confirmar_senha');
            const avisoSenhas = document.getElementById('aviso-senhas');

            const reqTamanho = document.getElementById('req-tamanho');
            const reqMaiuscula = document.getElementById('req-maiuscula');
            const reqNumero = document.getElementById('req-numero');

            function verificarRequisito(elemento, ok) {
                /*verifica o ícone que está mostrando e se preenche os requisitos */
                const icone = elemento.querySelector('.icone');
                if (ok) {
                    elemento.classList.add('ok');
                    icone.textContent = '✓';
                } else {
                    elemento.classList.remove('ok');
                    icone.textContent = '✗';
                }
            }

            inputSenha.addEventListener('input', function () {
                /*executa toda vez que o campo senha é alterado */
                const val = inputSenha.value;

                verificarRequisito(reqTamanho, val.length >= 8); /* verifica se tem 8 caracteres */
                verificarRequisito(
                    reqMaiuscula,
                    /[A-Z]/.test(val)
                ); /*verifica se tem pelo menos uma letra maiúscula */
                verificarRequisito(
                    reqNumero,
                    /[0-9]/.test(val)
                ); /*verifica se tem ao menos um número */

                if (inputConfirmar.value.length > 0) checarConfirmacao();
            });

            function checarConfirmacao() {
                if (inputConfirmar.value === '') {
                    avisoSenhas.textContent = '';
                    avisoSenhas.className = 'aviso-senhas';
                    return; /*se estiver vazio, não mostra o aviso */
                }
                if (inputSenha.value === inputConfirmar.value) {
                    avisoSenhas.textContent = '✓ As senhas coincidem';
                    avisoSenhas.className = 'aviso-senhas ok';
                } else {
                    avisoSenhas.textContent = '✗ As senhas não coincidem';
                    avisoSenhas.className = 'aviso-senhas erro';
                }
            }

            inputConfirmar.addEventListener('input', checarConfirmacao);

            // confirmação email
            const inputEmail = document.getElementById('email');
            const avisoEmail = document.getElementById('aviso-email');

            inputEmail.addEventListener('input', function () {
                const val = inputEmail.value;

                if (val === '') {
                    avisoEmail.textContent = '';
                    avisoEmail.className = 'aviso-senhas';
                    return; /* campo vazio, não mostra nada */
                }

                const emailValido = /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(val); //verifica se segue o modelo algo@algo.algo

                if (emailValido) {
                    avisoEmail.textContent = '✓ E-mail válido';
                    avisoEmail.className = 'aviso-senhas ok';
                } else {
                    avisoEmail.textContent = '✗ E-mail inválido';
                    avisoEmail.className = 'aviso-senhas erro';
                }
            });

            //verificação se emails coincidem
            const inputConfirmarEmail = document.getElementById('confirmar_email');
            const avisoConfirmarEmail = document.getElementById('aviso-confirmar-email');

            function checarConfirmacaoEmail() {
                if (inputConfirmarEmail.value === '') {
                    avisoConfirmarEmail.textContent = '';
                    avisoConfirmarEmail.className = 'aviso-senhas';
                    return;
                }
                if (inputEmail.value === inputConfirmarEmail.value) {
                    avisoConfirmarEmail.textContent = '✓ Os e-mails coincidem';
                    avisoConfirmarEmail.className = 'aviso-senhas ok';
                } else {
                    avisoConfirmarEmail.textContent = '✗ Os e-mails não coincidem';
                    avisoConfirmarEmail.className = 'aviso-senhas erro';
                }
            }

            inputConfirmarEmail.addEventListener('input', checarConfirmacaoEmail);

            // atualiza o aviso de confirmação se a pessoa editar o email depois
            inputEmail.addEventListener('input', function () {
                if (inputConfirmarEmail.value.length > 0) checarConfirmacaoEmail();
            });

            const btnCriar = document.querySelector('#form-cadastro button[type="submit"]');
            const campoNome = document.getElementById('nome');

            function atualizarBotaoCadastro() {
                const tudo_preenchido =
                    campoNome.value.trim() !== '' && //remove espaços em brancos
                    inputCpf.value.trim() !== '' &&
                    inputEmail.value.trim() !== '' &&
                    inputConfirmarEmail.value.trim() !== '' &&
                    inputSenha.value.trim() !== '' &&
                    inputConfirmar.value.trim() !== '';

                if (tudo_preenchido) {
                    btnCriar.classList.add('botao-pronto');
                } else {
                    btnCriar.classList.remove('botao-pronto');
                }
            }

            campoNome.addEventListener('input', atualizarBotaoCadastro); //verifica toda vez que o campo é atualizado
            inputCpf.addEventListener('input', atualizarBotaoCadastro)
            inputEmail.addEventListener('input', atualizarBotaoCadastro);
            inputConfirmarEmail.addEventListener('input', atualizarBotaoCadastro);
            inputSenha.addEventListener('input', atualizarBotaoCadastro);
            inputConfirmar.addEventListener('input', atualizarBotaoCadastro);
        </script>

        <!-- VLibras: tradutor de conteúdo para Libras -->
        <div vw class="enabled">
            <div vw-access-button class="active"></div>
            <div vw-plugin-wrapper>
                <div class="vw-plugin-top-wrapper"></div>
            </div>
        </div>
        <script src="https://vlibras.gov.br/app/vlibras-plugin.js"></script>
        <script>
            new window.VLibras.Widget('https://vlibras.gov.br/app');
        </script>
    </body>
</html>
